{
  "name": "mold-costs-estimate-calculator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation next dev",
    "build": "NODE_OPTIONS=--no-deprecation next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start": "NODE_OPTIONS=--no-deprecation next start -p ${PORT:-3000}",
    "start:standalone": "NODE_OPTIONS=--no-deprecation node -r dotenv/config .next/standalone/server.js dotenv_config_path=.env.local",
    "lint": "eslint"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1"
  }
}
